<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PlatformTarget>x64</PlatformTarget>
    <UserSecretsId>cc1ef1e4-0885-41c9-95c3-89fa0284fcf0</UserSecretsId>
    <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
    <DockerfileContext>.</DockerfileContext>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Anthropic" Version="12.16.0" />
    <PackageReference Include="Basic.Reference.Assemblies.Net80" Version="1.8.5" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="9.*">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" Version="9.*" />
    <PackageReference Include="System.IO.Packaging" Version="8.0.1" GeneratePathProperty="true" />
    <PackageReference Include="DocumentFormat.OpenXml" Version="3.5.1" GeneratePathProperty="true" />
    <PackageReference Include="DocumentFormat.OpenXml.Framework" Version="3.5.1" GeneratePathProperty="true" />
    <PackageReference Include="DotNetEnv" Version="3.1.1" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.*" />
    <PackageReference Include="Microsoft.NETFramework.ReferenceAssemblies.net48" Version="1.0.3" GeneratePathProperty="true">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.VisualStudio.Azure.Containers.Tools.Targets" Version="1.22.1" />
    <PackageReference Include="OpenAI" Version="2.*" />
    <PackageReference Include="System.Reflection.MetadataLoadContext" Version="10.0.7" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="ZwDatabaseMgd">
      <HintPath>Libraries\Zwcad\ZwDatabaseMgd.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="ZwManaged">
      <HintPath>Libraries\Zwcad\ZwManaged.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <Content Include="Libraries\Zwcad\*.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <Link>Libraries/Zwcad/%(Filename)%(Extension)</Link>
    </Content>
    <Content Include="Libraries\Autocad\*.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <Link>Libraries/Autocad/%(Filename)%(Extension)</Link>
    </Content>
    <Content Include="Libraries\Bricscad\*.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <Link>Libraries/Bricscad/%(Filename)%(Extension)</Link>
    </Content>
    <Content Include="Libraries\Gstarcad\*.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <Link>Libraries/Gstarcad/%(Filename)%(Extension)</Link>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Libraries\Autocad\" />
    <Folder Include="Libraries\Bricscad\" />
    <Folder Include="Libraries\Gstarcad\" />
    <Folder Include="Libraries\Zwcad\" />
    <Folder Include="Migrations\" />
  </ItemGroup>

  <!-- Kopiuj dodatkowe biblioteki (net46) do Libraries/Extra/ — dla ZWCAD/AutoCAD/BricsCAD -->
  <Target Name="CopyExtraLibs" AfterTargets="ResolvePackageAssets">
    <ItemGroup>
      <ExtraLibFiles Include="$(PkgDocumentFormat_OpenXml)\lib\net46\DocumentFormat.OpenXml.dll" />
      <ExtraLibFiles Include="$(PkgDocumentFormat_OpenXml_Framework)\lib\net46\DocumentFormat.OpenXml.Framework.dll" />
    </ItemGroup>
    <Copy SourceFiles="@(ExtraLibFiles)" DestinationFolder="$(OutDir)Libraries\Extra\" SkipUnchangedFiles="true" />
  </Target>

  <Target Name="CopyExtraLibsOnPublish" AfterTargets="Publish">
    <ItemGroup>
      <ExtraLibFilesPublish Include="$(PkgDocumentFormat_OpenXml)\lib\net46\DocumentFormat.OpenXml.dll" />
      <ExtraLibFilesPublish Include="$(PkgDocumentFormat_OpenXml_Framework)\lib\net46\DocumentFormat.OpenXml.Framework.dll" />
    </ItemGroup>
    <Copy SourceFiles="@(ExtraLibFilesPublish)" DestinationFolder="$(PublishDir)Libraries\Extra\" SkipUnchangedFiles="true" />
  </Target>

  <!-- Kopiuj dodatkowe biblioteki (net8.0) do Libraries/Extra.NetCore/ — dla GstarCAD -->
  <Target Name="CopyExtraLibsNetCore" AfterTargets="ResolvePackageAssets">
    <ItemGroup>
      <ExtraLibFilesNetCore Include="$(PkgDocumentFormat_OpenXml)\lib\net8.0\DocumentFormat.OpenXml.dll" />
      <ExtraLibFilesNetCore Include="$(PkgDocumentFormat_OpenXml_Framework)\lib\net8.0\DocumentFormat.OpenXml.Framework.dll" />
      <ExtraLibFilesNetCore Include="$(PkgSystem_IO_Packaging)\lib\net8.0\System.IO.Packaging.dll" Condition="Exists('$(PkgSystem_IO_Packaging)\lib\net8.0\System.IO.Packaging.dll')" />
    </ItemGroup>
    <Copy SourceFiles="@(ExtraLibFilesNetCore)" DestinationFolder="$(OutDir)Libraries\Extra.NetCore\" SkipUnchangedFiles="true" />
  </Target>

  <Target Name="CopyExtraLibsNetCoreOnPublish" AfterTargets="Publish">
    <ItemGroup>
      <ExtraLibFilesNetCorePublish Include="$(PkgDocumentFormat_OpenXml)\lib\net8.0\DocumentFormat.OpenXml.dll" />
      <ExtraLibFilesNetCorePublish Include="$(PkgDocumentFormat_OpenXml_Framework)\lib\net8.0\DocumentFormat.OpenXml.Framework.dll" />
      <ExtraLibFilesNetCorePublish Include="$(PkgSystem_IO_Packaging)\lib\net8.0\System.IO.Packaging.dll" Condition="Exists('$(PkgSystem_IO_Packaging)\lib\net8.0\System.IO.Packaging.dll')" />
    </ItemGroup>
    <Copy SourceFiles="@(ExtraLibFilesNetCorePublish)" DestinationFolder="$(PublishDir)Libraries\Extra.NetCore\" SkipUnchangedFiles="true" />
  </Target>

  <!-- Kopiuj assemblies .NET Framework 4.8 do OutDir (build) -->
  <Target Name="CopyNetFx48Refs" AfterTargets="ResolvePackageAssets">
    <ItemGroup>
      <NetFx48Files Include="$(PkgMicrosoft_NETFramework_ReferenceAssemblies_net48)\build\.NETFramework\v4.8\*.dll" />
    </ItemGroup>
    <Copy SourceFiles="@(NetFx48Files)" DestinationFolder="$(OutDir)NetFx48\" SkipUnchangedFiles="true" />
  </Target>

  <!-- Kopiuj assemblies .NET Framework 4.8 do PublishDir (dotnet publish) -->
  <Target Name="CopyNetFx48RefsOnPublish" AfterTargets="Publish">
    <ItemGroup>
      <NetFx48FilesPublish Include="$(PkgMicrosoft_NETFramework_ReferenceAssemblies_net48)\build\.NETFramework\v4.8\*.dll" />
    </ItemGroup>
    <Copy SourceFiles="@(NetFx48FilesPublish)" DestinationFolder="$(PublishDir)NetFx48\" SkipUnchangedFiles="true" />
  </Target>

</Project>
